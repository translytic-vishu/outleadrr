# ── Database ────────────────────────────────────────────────────────
# Get a free PostgreSQL DB at https://neon.tech
DATABASE_URL=postgresql://username:password@host/dbname

# ── Google Places API ────────────────────────────────────────────────
# Get at https://console.cloud.google.com → APIs & Services → Credentials
# Enable: Places API
GOOGLE_PLACES_API_KEY=AIza...

# ── Google OAuth 2.0 ─────────────────────────────────────────────────
# Get at https://console.cloud.google.com → APIs & Services → OAuth 2.0
# Add redirect URI: https://yourdomain.vercel.app/api/auth/google/callback
GOOGLE_CLIENT_ID=123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── OpenAI ────────────────────────────────────────────────────────────
# Get at https://platform.openai.com/api-keys
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# ── Session ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-random-32-char-secret-here

# ── Server ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
